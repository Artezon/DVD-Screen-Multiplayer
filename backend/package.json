    "format": "prettier --write src/"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
